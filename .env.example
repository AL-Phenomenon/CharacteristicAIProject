# LLM Provider (anthropic or openai)
LLM_PROVIDER=openai

# Anthropic API Key (Claudeを使う場合)
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI Compatible API (LM Studioなど)
OPENAI_API_KEY=not-needed  # LM StudioではダミーでもOK
OPENAI_BASE_URL=http://localhost:1234/v1

# Model Configuration
MODEL_NAME=local-model  # LM Studioで読み込んだモデル名
MAX_TOKENS=1000

# Character Configuration
COMPACT_PROMPT=true  # true=簡潔版プロンプト（推奨）、false=詳細版プロンプト

# Interface Mode (cli, gui, discord, or web)
INTERFACE_MODE=gui  # cli=コマンドライン、gui=ウィンドウ、discord=Discord Bot、web=Webサーバー

# Web Server Configuration (INTERFACE_MODE=webの場合)
WEB_HOST=0.0.0.0  # 0.0.0.0=LAN全体に公開、127.0.0.1=ローカルのみ
WEB_PORT=8080      # ポート番号（変更可能）

# Discord Bot Configuration (INTERFACE_MODE=discordの場合に必要)
DISCORD_BOT_TOKEN=
DISCORD_STATUS_MESSAGE=HARKAと会話中  # Botのステータスメッセージ（任意）

# Memory Configuration
CHROMA_DB_PATH=./data/chroma_db
COLLECTION_NAME=chat_memory
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# RAG Configuration
MAX_MEMORY_RESULTS=3  # 過去の記憶の取得数（減らすと速くなる）
SHORT_TERM_MEMORY_SIZE=5
MAX_PDF_RESULTS=2  # PDFから取得する関連情報の最大件数
PDF_MIN_RELEVANCE=0.3  # これより関連度が低いPDF情報は無視する